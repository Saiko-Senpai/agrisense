# ============================================================
# AgriSense Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# OpenWeatherMap API Key
# Get yours free at: https://openweathermap.org/api
# Free tier: 1,000 calls/day — more than enough for development
NEXT_PUBLIC_OPENWEATHER_API_KEY=your_openweather_api_key_here

# Optional: Agmarknet / data.gov.in for live market prices
# Register at: https://data.gov.in/catalogs/agriculture
# NEXT_PUBLIC_AGMARKNET_API_KEY=your_agmarknet_api_key_here
